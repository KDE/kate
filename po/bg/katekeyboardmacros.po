#: keyboardmacrosplugin.cpp:66 keyboardmacrosplugin.cpp:102
#, kde-format
msgid "Could not open file '%1'."
msgstr "Грешка при отваряне на файла %1"

#: keyboardmacrosplugin.cpp:72
#, kde-format
msgid "Malformed JSON file '%1': %2"
msgstr "Неправилен JSON файл „%1“: %2"

#: keyboardmacrosplugin.cpp:80
#, kde-format
msgid "Could not load '%1': malformed macro; wiping it."
msgstr "Неуспешно зареждане на '%1': невалиден макрос; изчистване."

#. i18n: ectx: ToolBar (keyboardmacros)
#: keyboardmacrosplugin.cpp:120 keyboardmacrospluginview.cpp:30
#: keyboardmacrospluginview.cpp:289 keyboardmacrospluginview.cpp:323 ui.rc:12
#, kde-format
msgid "Keyboard Macros"
msgstr "Клавиатурни макроси"

#: keyboardmacrosplugin.cpp:129
#, kde-format
msgid "<b>Keyboard Macros:</b> %1"
msgstr "<b>Клавиатурни макроси:</b> %1"

#: keyboardmacrosplugin.cpp:170
#, kde-format
msgid "Can't save macro during recording. Please end recoding first"
msgstr ""
"Неуспешно запазване на макрос по време на запис. Моля, прекратете "
"записването първо."

#: keyboardmacrosplugin.cpp:241
#, kde-format
msgid "Recording…"
msgstr "Записване…"

#: keyboardmacrosplugin.cpp:277
#, kde-format
msgid "ended"
msgstr "завършено"

#: keyboardmacrosplugin.cpp:277
#, kde-format
msgid "canceled"
msgstr "отменено"

#: keyboardmacrosplugin.cpp:277
#, kde-format
msgid "Recording %1"
msgstr "Записване %1"

#: keyboardmacrosplugin.cpp:327
#, kde-format
msgid "Saved '%1'"
msgstr "Запазено „%1“"

#: keyboardmacrosplugin.cpp:347
#, kde-format
msgid "Loaded '%1'"
msgstr "Заредено „%1“"

#: keyboardmacrosplugin.cpp:365
#, kde-format
msgid "Wiped '%1'"
msgstr "Изчистено „%1“"

#: keyboardmacrosplugincommands.cpp:27
#, kde-format
msgid "Usage: %1 <name>."
msgstr "Употреба: %1 <name>."

#: keyboardmacrosplugincommands.cpp:41 keyboardmacrosplugincommands.cpp:56
#: keyboardmacrosplugincommands.cpp:62
#, kde-format
msgid "No keyboard macro named '%1' found."
msgstr "Не е намерен клавиатурен макрос с име ‘%1’."

#: keyboardmacrosplugincommands.cpp:50
#, kde-format
msgid "Cannot save empty keyboard macro."
msgstr "Не може да се запази празен клавиатурен макрос."

#: keyboardmacrosplugincommands.cpp:82
#, kde-format
msgid ""
"<qt><p>Usage: <code>kmsave &lt;name&gt;</code></p><p>Save current keyboard "
"macro as <code>&lt;name&gt;</code>.</p>%1</qt>"
msgstr ""
"<qt><p>Използване: <code>kmsave &lt;име&gt;</code></p><p>Запазване на "
"текущия клавиатурен макрос като <code>&lt;име&gt;</code>.</p>%1</qt>"

#: keyboardmacrosplugincommands.cpp:85
#, kde-format
msgid ""
"<qt><p>Usage: <code>kmload &lt;name&gt;</code></p><p>Load saved keyboard "
"macro <code>&lt;name&gt;</code> as current macro.</p>%1</qt>"
msgstr ""
"<qt><p>Начин на употреба: <code>kmload &lt;име&gt;</code></p><p>Зареждане на "
"запазен клавиатурен макрос <code>&lt;име&gt;</code> като текущ макрос.</p>"
"%1</qt>"

#: keyboardmacrosplugincommands.cpp:89
#, kde-format
msgid ""
"<qt><p>Usage: <code>kmplay &lt;name&gt;</code></p><p>Play saved keyboard "
"macro <code>&lt;name&gt;</code> without loading it.</p>%1</qt>"
msgstr ""
"<qt><p>Начин на употреба: <code>kmplay &lt;име&gt;</code></"
"p><p>Възпроизвеждане на запазен клавиатурен макрос <code>&lt;име&gt;</code> "
"без зареждане.</p>%1</qt>"

#: keyboardmacrosplugincommands.cpp:93
#, kde-format
msgid ""
"<qt><p>Usage: <code>kmwipe &lt;name&gt;</code></p><p>Wipe saved keyboard "
"macro <code>&lt;name&gt;</code>.</p>%1</qt>"
msgstr ""
"<qt><p>Начин на употреба: <code>kmwipe &lt;име&gt;</code></p><p>Изтриване на "
"запазения клавиатурен макрос <code>&lt;име&gt;</code>.</p>%1</qt>"

#: keyboardmacrospluginview.cpp:33
#, kde-format
msgid "&Keyboard Macros"
msgstr "&Клавиатурни макроси"

#: keyboardmacrospluginview.cpp:36
#, kde-format
msgid "Record and play keyboard macros."
msgstr "Запис и изпълнение на клавиатурни макроси."

#: keyboardmacrospluginview.cpp:41 keyboardmacrospluginview.cpp:163
#, kde-format
msgid "&Record Macro..."
msgstr "&Запис на макрос..."

#: keyboardmacrospluginview.cpp:43
#, kde-format
msgid "Start/stop recording a macro (i.e., keyboard action sequence)."
msgstr ""
"Започване/спиране на запис на макрос (т.е. последователност от действия на "
"клавиатурата)."

#: keyboardmacrospluginview.cpp:52
#, kde-format
msgid "&Cancel Macro Recording"
msgstr "&Прекратяване на запис на макрос"

#: keyboardmacrospluginview.cpp:54
#, kde-format
msgid ""
"Cancel ongoing recording (and keep the previous macro as the current one)."
msgstr ""
"Прекъсване на текущото записване (и запазване на предишния макрос като "
"текущ)."

#: keyboardmacrospluginview.cpp:64
#, kde-format
msgid "&Play Macro"
msgstr "&Изпълнение на макрос"

#: keyboardmacrospluginview.cpp:66
#, kde-format
msgid ""
"Play current macro (i.e., execute the last recorded keyboard action "
"sequence)."
msgstr ""
"Изпълнение на текущия макрос (т.е. изпълнение на последната записана "
"последователност от действия с клавиатурата)."

#: keyboardmacrospluginview.cpp:76
#, kde-format
msgid "&Save Current Macro"
msgstr "Запазване на текущия макрос"

#: keyboardmacrospluginview.cpp:78
#, kde-format
msgid "Give a name to the current macro and persistently save it."
msgstr "Дайте име на текущия макрос и го запазете за постоянно."

#: keyboardmacrospluginview.cpp:90
#, kde-format
msgid "&Load Named Macro..."
msgstr "Зареждане на именуван макрос..."

#: keyboardmacrospluginview.cpp:93
#, kde-format
msgid "Load a named macro as the current one."
msgstr "Зареждане на именуван макрос като текущ."

#: keyboardmacrospluginview.cpp:98
#, kde-format
msgid "&Play Named Macro..."
msgstr "&Изпълнение на именуван макро..."

#: keyboardmacrospluginview.cpp:101
#, kde-format
msgid "Play a named macro without loading it."
msgstr "Изпълнение на именуван макрос без зареждане."

#: keyboardmacrospluginview.cpp:106
#, kde-format
msgid "&Wipe Named Macro..."
msgstr "&Изтриване на именуван макрос…"

#: keyboardmacrospluginview.cpp:109
#, kde-format
msgid "Wipe a named macro."
msgstr "Изтриване на макрос със зададено име."

#: keyboardmacrospluginview.cpp:155
#, kde-format
msgid "End Macro &Recording"
msgstr "Край на запис на макрос"

#: keyboardmacrospluginview.cpp:180
#, kde-format
msgid "Load %1"
msgstr "Зареждане на %1"

#: keyboardmacrospluginview.cpp:181
#, kde-format
msgid "Load the '%1' macro as the current one."
msgstr "Зареждане на макрос %1 като текущ."

#: keyboardmacrospluginview.cpp:193
#, kde-format
msgid "Play %1"
msgstr "Игра %1"

#: keyboardmacrospluginview.cpp:194
#, kde-format
msgid "Play the '%1' macro without loading it."
msgstr "Изпълнение на макрос %1 без зареждане."

#: keyboardmacrospluginview.cpp:208
#, kde-format
msgid "Wipe %1"
msgstr "Изтриване на %1"

#: keyboardmacrospluginview.cpp:209
#, kde-format
msgid "Wipe the '%1' macro."
msgstr "Изтриване на макрос %1."

#: keyboardmacrospluginview.cpp:289
#, kde-format
msgid "Save current macro as?"
msgstr "Запазване на текущия макрос като?"

#: keyboardmacrospluginview.cpp:323
#, kde-format
msgid "Wipe the '%1' macro?"
msgstr "Да се изтрие ли макрос '%1'?"

#. i18n: ectx: Menu (tools)
#: ui.rc:6
#, kde-format
msgid "&Tools"
msgstr "&Инструменти"
