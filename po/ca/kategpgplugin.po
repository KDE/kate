#: gpgmeppwrapper.cpp:83
#, kde-format
msgid "Error! No keys found..."
msgstr "Error! No s'ha trobat cap clau..."

#: gpgmeppwrapper.cpp:133 gpgmeppwrapper.cpp:135
#, kde-format
msgid "Error finding key: "
msgstr "Error en cercar la clau: "

#: gpgmeppwrapper.cpp:223 gpgmeppwrapper.cpp:225
#, kde-format
msgid "Error in symmetric encryption: "
msgstr "Error en l'encriptatge simètric: "

#: gpgmeppwrapper.cpp:241 gpgmeppwrapper.cpp:243
#, kde-format
msgid "Encryption Failed: "
msgstr "Ha fallat l'encriptatge: "

#: kategpgplugin.cpp:70
#, kde-format
msgid "GPG Plugin"
msgstr "Connector GPG"

#: kategpgplugin.cpp:75
#, kde-format
msgid "GPG Decrypt current document"
msgstr "El GPG desencripta el document actual"

#: kategpgplugin.cpp:76
#, kde-format
msgid "GPG Encrypt current document"
msgstr "El GPG encripta el document actual"

#: kategpgplugin.cpp:80
#, kde-format
msgid "<b>GPG Plugin Settings</b>"
msgstr "<b>Configuració del connector GPG</b>"

#: kategpgplugin.cpp:83
#, kde-format
msgid "Key ID"
msgstr "ID de la clau"

#: kategpgplugin.cpp:84
#, kde-format
msgid "A search string used to filter keys by available email addresses"
msgstr ""
"Una cadena de cerca usada per a filtrar claus per adreces disponibles de "
"correu electrònic"

#: kategpgplugin.cpp:87
#, kde-format
msgid "Selected GPG Key finerprint for encryption"
msgstr "Empremta digital de la clau GPG seleccionada per a l'encriptatge"

#: kategpgplugin.cpp:88
#, kde-format
msgid "<b>To: Email address used for encryption</b>"
msgstr "<b>A: Adreça de correu electrònic utilitzada per a l'encriptatge</b>"

#: kategpgplugin.cpp:97
#, kde-format
msgid ""
"Select an email address to which to encrypt.\n"
"Only mail addresses associated with your currently selected\n"
"key fingerprint are available."
msgstr ""
"Seleccioneu una adreça de correu electrònic a la qual encriptar.\n"
"Només estan disponibles les adreces de correu associades amb l'empremta "
"digital de la clau seleccionada actualment."

#: kategpgplugin.cpp:101
#, kde-format
msgid ""
"This is your currently selected GPG key fingerprint that will be used for "
"encryption."
msgstr ""
"Aquesta és la vostra empremta digital de la clau GPG seleccionada que "
"s'utilitzarà per a l'encriptatge."

#: kategpgplugin.cpp:104
#, kde-format
msgid "Enable symmetric encryption"
msgstr "Activa l'encriptatge simètric"

#: kategpgplugin.cpp:107
#, kde-format
msgid "Show only keys for which a private key is available"
msgstr ""
"Mostra només les claus per a les quals hi ha disponible una clau privada"

#: kategpgplugin.cpp:110
#, kde-format
msgid "Hide Expired Keys"
msgstr "Oculta les claus vençudes"

#: kategpgplugin.cpp:223
#, kde-format
msgid "  Decrypted  "
msgstr "  Desencriptat  "

#: kategpgplugin.cpp:229
#, kde-format
msgid "  Encrypted  "
msgstr "  Encriptat  "

#: kategpgplugin.cpp:320 kategpgplugin.cpp:451
#, kde-format
msgid "Error Decrypting Text! No fingerprint selected..."
msgstr ""
"Error en desencriptar el text! No s'ha seleccionat cap empremta digital..."

#: kategpgplugin.cpp:326 kategpgplugin.cpp:456
#, kde-format
msgid ""
"Error Decrypting Text!\n"
"No matching fingerprint found!\n"
"Or this is not a GPG encrypted text..."
msgstr ""
"Error en desencriptar el text!\n"
"No s'ha trobat cap empremta digital coincident!\n"
"O això no és un text encriptat amb GPG..."

#: kategpgplugin.cpp:334 kategpgplugin.cpp:464
#, kde-format
msgid "Error Decrypting Text!\n"
msgstr "Error en desencriptar el text!\n"

#: kategpgplugin.cpp:416 kategpgplugin.cpp:503
#, kde-format
msgid ""
"Error Encrypting Text!\n"
"No fingerprint selected..."
msgstr ""
"Error en encriptar el text\n"
"No s'ha seleccionat cap empremta digital..."

#: kategpgplugin.cpp:423 kategpgplugin.cpp:547
#, kde-format
msgid "Error Encrypting Text! No Matching Fingerprint found...\n"
msgstr ""
"Error en encriptar el text! No s'ha trobat cap empremta digital "
"coincident...\n"

#: kategpgplugin.cpp:427 kategpgplugin.cpp:551
#, kde-format
msgid "Error Encrypting Text!"
msgstr "Error en encriptar el text!"

#: kategpgplugin.cpp:443 kategpgplugin.cpp:490
#, kde-format
msgid "Error! No views available..."
msgstr "Error! No hi ha vistes disponibles..."

#: kategpgplugin.cpp:447
#, kde-format
msgid "Error Decrypting Text! Document is empty..."
msgstr "Error en desencriptar el text! El document és buit..."

#: kategpgplugin.cpp:495
#, kde-format
msgid "Error Encrypting Text! No document available..."
msgstr "Error en encriptar el text! No hi ha cap document disponible..."

#: kategpgplugin.cpp:499
#, kde-format
msgid "Error Encrypting Text! Document is empty..."
msgstr "Error en encriptar el text! El document és buit..."

#: kategpgplugin.cpp:507
#, kde-format
msgid ""
"Attempted double encryption detected! Encrypting twice is disabled for now..."
msgstr ""
"S'ha detectat un intent de xifratge doble! Encriptar dues vegades està "
"desactivat per ara..."

#: kategpgplugin.cpp:528
#, kde-format
msgid "Save Encrypted File As"
msgstr "Desa el fitxer encriptat com a"

#: kategpgplugin.cpp:530
#, kde-format
msgid "GPG Files (*.gpg *.asc)"
msgstr "Fitxers GPG (*.gpg *.asc)"

#: kategpgplugin.cpp:619
#, kde-format
msgid "Key Fingerprint"
msgstr "Empremta digital de la clau"

#: kategpgplugin.cpp:619
#, kde-format
msgid "Creation Date"
msgstr "Data de creació"

#: kategpgplugin.cpp:619
#, kde-format
msgid "Expiry Date"
msgstr "Data de venciment"

#: kategpgplugin.cpp:619
#, kde-format
msgid "Key Length"
msgstr "Longitud de la clau"

#: kategpgplugin.cpp:619
#, kde-format
msgid "User IDs"
msgstr "ID d'usuaris"

#~ msgid "Save as ASCII encoded (.asc/.gpg)"
#~ msgstr "Desa com a codificat ASCII (.asc/.gpg)"

#~ msgid ""
#~ "Attempted double encryption detected!\n"
#~ "Encrypting more than once is disabled for now..."
#~ msgstr ""
#~ "S'ha detectat un intent d'encriptatge doble!\n"
#~ "L'encriptatge més d'una vegada està desactivat de moment..."

#~ msgid "Warning"
#~ msgstr "Avís"

