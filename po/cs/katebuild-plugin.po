#, kde-format
msgid "There is no file or directory specified for building."
msgstr "Pro sestavení není určen soubor nebo adresář."

#: plugin_katebuild.cpp:770
#, kde-format
msgid ""
"The file \"%1\" is not a local file. Non-local files cannot be compiled."
msgstr ""
"Soubor \"%1\" není místním souborem. Lze kopírovat pouze místní soubory."

#: plugin_katebuild.cpp:841
#, kde-format
msgid "Create directory"
msgstr "Vytvořit adresář"

#: plugin_katebuild.cpp:844
#, kde-format
msgid ""
"The configured working directory <b>%1</b> for the targetset <b>%2</b> does "
"not exist.<br><br>Create the directory?"
msgstr ""
"Nastavený pracovní adresář <b>%1</b> pro sadu cílů <b>%2</b> neexistuje."
"<br><br>Chcete adresář vytvořit?"

#: plugin_katebuild.cpp:852
#, kde-format
msgid "Failed to create the directory <b>%1</b>"
msgstr "Nepodařilo se vytvořit adresář <b>%1</b>"

#: plugin_katebuild.cpp:877
#, kde-format
msgid "Failed to run \"%1\". exitStatus = %2"
msgstr "Nepovedlo se spustit \"%1\". exitStatus = %2"

#: plugin_katebuild.cpp:893
#, kde-format
msgid "Building <b>%1: %2</b> cancelled"
msgstr "Sestavování <b>%1: %2</b> bylo zrušeno"

