#, kde-format
msgid "Did not find a compile command for file \"%1\" in \"%2\". "
msgstr "V \"%2\" nebyl nalezen příkaz pro kompilaci souboru \"%1\". "

#: plugin_katebuild.cpp:1031
#, kde-format
msgid ""
"Cannot make \"%f\" substitution. No open file or the current file is "
"untitled!"
msgstr ""
"Nelze provést nahrazení \"%f\". Žádný soubor není otevřený nebo aktuální "
"soubor nemá název!"

#: plugin_katebuild.cpp:1035
#, kde-format
msgid ""
"Cannot make \"%d\" substitution. No open file or the current file is "
"untitled!"
msgstr ""
"Nelze provést nahrazení \"%d\". Žádný soubor není otevřený nebo aktuální "
"soubor nemá název!"

#: plugin_katebuild.cpp:1039
#, kde-format
msgid ""
"Cannot make \"%n\" substitution. No open file or the current file is "
"untitled!"
msgstr ""
"Nelze provést nahrazení \"%n\". Žádný soubor není otevřený nebo aktuální "
"soubor nemá název!"

#: plugin_katebuild.cpp:1050
#, kde-format
msgid "Cannot make project substitution (%B). No open project!"
msgstr "Nelze provést nahrazení projektu (%B). Žádný projekt není otevřený!"

#: plugin_katebuild.cpp:1063
#, kde-format
msgid "Already building..."
msgstr "Sestavení již probíhá..."

#: plugin_katebuild.cpp:1101
#, kde-format
msgid ""
"Cannot execute: %1: %2 No working directory set.\n"
"There is no local file or directory specified for building."
msgstr ""
"Nelze spustit: %1: %2 Není nastaven pracovní adresář.\n"
"Pro sestavení nebyl zadán žádný místní soubor ani adresář."

#: plugin_katebuild.cpp:1222
#, kde-format
msgid "Building target <b>%1: %2</b> ..."
msgstr "Sestavení cíle <b>%1: %2</b> ..."

#: plugin_katebuild.cpp:1259
#, kde-format
msgid ""
"Cannot load targets, the file %1 does not contain a proper CMAKE_COMMAND "
"entry !"
msgstr "Nelze načíst cíle, soubor %1 neobsahuje správný záznam CMAKE_COMMAND!"

#: plugin_katebuild.cpp:1272
#, kde-format
msgid "Could not write CMake File API query files for build directory %1 !"
msgstr ""
"Nepodařilo se zapsat soubory dotazů CMake File API pro adresář sestavení %1!"

#: plugin_katebuild.cpp:1278
#, kde-format
msgid "Could not run CMake (%2) for build directory %1 !"
msgstr "Nepodařilo se spustit CMake (%2) pro adresář sestavení %1!"

#: plugin_katebuild.cpp:1287
#, kde-format
msgid ""
"Generating CMake File API reply files for build directory %1 failed (using "
"%2) !"
msgstr ""
"Generování souborů odpovědí API pro CMake pro adresář sestavení %1 selhalo "
"(při použití %2)!"

#: plugin_katebuild.cpp:1412
#, kde-format
msgid "Build plugin wants to execute program"
msgstr "Modul pro sestavení se pokouší spustit program"

#: plugin_katebuild.cpp:1415
#, kde-format
msgid ""
"The Kate build plugin needs to execute an external command to read the "
"targets from the build tree.<br><br>The full command line is:<br><br><b>%1</"
"b><br><br>Proceed and allow to run this command ?<br><br>The choice can be "
"altered via the config page of the plugin."
msgstr ""
"Modul Kate pro sestavení musí spustit externí příkaz, aby načítal cíle ze "
"stromu sestavení.<br><br>Úplný příkazový řádek zní:<br><br><b>%1</"
"b><br><br>Chcete pokračovat a povolit spuštění tohoto příkazu?<br><br>Tuto "
"volbu lze změnit na stránce nastavení modulu."

