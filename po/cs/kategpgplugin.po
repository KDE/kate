#: gpgmeppwrapper.cpp:83
#, kde-format
msgid "Error! No keys found..."
msgstr "Chyba! Nebyly nalezeny žádné klíče..."

#: gpgmeppwrapper.cpp:133 gpgmeppwrapper.cpp:135
#, kde-format
msgid "Error finding key: "
msgstr "Chyba při vyhledávání klíče: "

#: gpgmeppwrapper.cpp:221 gpgmeppwrapper.cpp:223
#, kde-format
msgid "Error in symmetric encryption: "
msgstr "Chyba při symetrickém šifrování: "

#: gpgmeppwrapper.cpp:239 gpgmeppwrapper.cpp:241
#, kde-format
msgid "Encryption Failed: "
msgstr "Šifrování selhalo: "

#: kategpgplugin.cpp:73
#, kde-format
msgid "GPG Plugin"
msgstr "Modul GPG"

#: kategpgplugin.cpp:78
#, kde-format
msgid "GPG Decrypt current document"
msgstr "Dešifrovat aktuální dokument pomocí GPG"

#: kategpgplugin.cpp:79
#, kde-format
msgid "GPG Encrypt current document"
msgstr "Zašifrovat aktuální dokument pomocí GPG"

#: kategpgplugin.cpp:83
#, kde-format
msgid "<b>GPG Plugin Settings</b>"
msgstr "<b>Nastavení modulu GPG</b>"

#: kategpgplugin.cpp:86
#, kde-format
msgid "Key ID"
msgstr "ID klíče"

#: kategpgplugin.cpp:87
#, kde-format
msgid "A search string used to filter keys by available email addresses"
msgstr ""
"Vyhledávací řetězec sloužící k filtrování klíčů podle dostupných e-mailových "
"adres"

#: kategpgplugin.cpp:90
#, kde-format
msgid "Selected GPG Key finerprint for encryption"
msgstr "Otisk vybraného klíče GPG pro šifrování"

#: kategpgplugin.cpp:91
#, kde-format
msgid "<b>To: Email address used for encryption</b>"
msgstr "<b>Komu: E-mailová adresa použitá pro šifrování</b>"

#: kategpgplugin.cpp:100
#, kde-format
msgid ""
"Select an email address to which to encrypt.\n"
"Only mail addresses associated with your currently selected\n"
"key fingerprint are available."
msgstr ""
"Vyberte e-mailovou adresu, na kterou chcete zprávu zašifrovat.\n"
"K dispozici jsou pouze e-mailové adresy spojené s aktuálně vybraným\n"
"otiskem klíče."

#: kategpgplugin.cpp:104
#, kde-format
msgid ""
"This is your currently selected GPG key fingerprint that will be used for "
"encryption."
msgstr ""
"Toto je otisk aktuálně vybraného klíče GPG, který bude použit pro šifrování."

#: kategpgplugin.cpp:107
#, kde-format
msgid "Save as ASCII encoded (.asc/.gpg)"
msgstr "Uložit jako soubor v kódování ASCII (.asc/.gpg)"

#: kategpgplugin.cpp:110
#, kde-format
msgid "Enable symmetric encryption"
msgstr "Zapnout symetrické šifrování"

#: kategpgplugin.cpp:113
#, kde-format
msgid "Show only keys for which a private key is available"
msgstr "Zobrazit pouze klíče, pro které je k dispozici soukromý klíč"

#: kategpgplugin.cpp:116
#, kde-format
msgid "Hide Expired Keys"
msgstr "Skrýt vypršené klíče"

#: kategpgplugin.cpp:217
#, kde-format
msgid ""
"Attempted double encryption detected!\n"
"Encrypting more than once is disabled for now..."
msgstr ""
"Zjištěn pokus o dvojité šifrování!\n"
"Vícenásobné šifrování je prozatím zakázáno..."

#: kategpgplugin.cpp:231 kategpgplugin.cpp:274
#, kde-format
msgid "Error! No views available..."
msgstr "Chyba! Žádné zobrazení není k dispozici..."

#: kategpgplugin.cpp:236
#, kde-format
msgid "Error Decrypting Text! Document is empty..."
msgstr "Chyba při dešifrování textu! Dokument je prázdný..."

#: kategpgplugin.cpp:240
#, kde-format
msgid "Error Decrypting Text! No fingerprint selected..."
msgstr "Chyba při dešifrování textu! Nebyl vybrán žádný otisk..."

#: kategpgplugin.cpp:245
#, kde-format
msgid ""
"Error Decrypting Text!\n"
"No matching fingerprint found!\n"
"Or this is not a GPG encrypted text..."
msgstr ""
"Chyba při dešifrování textu!\n"
"Nenalezen žádný odpovídající otisk!\n"
"Nebo se nejedná o text zašifrovaný pomocí GPG..."

#: kategpgplugin.cpp:253
#, kde-format
msgid "Error Decrypting Text!\n"
msgstr "Chyba při dešifrování textu!\n"

#: kategpgplugin.cpp:280
#, kde-format
msgid "Error Encrypting Text! No document available..."
msgstr "Chyba při šifrování textu! Dokument není k dispozici..."

#: kategpgplugin.cpp:284
#, kde-format
msgid "Error Encrypting Text! Document is empty..."
msgstr "Chyba při šifrování textu! Dokument je prázdný..."

#: kategpgplugin.cpp:288
#, kde-format
msgid ""
"Error Encrypting Text!\n"
"No fingerprint selected..."
msgstr ""
"Chyba při šifrování textu!\n"
"Není vybrán žádný otisk..."

#: kategpgplugin.cpp:292
#, kde-format
msgid ""
"Attempted double encryption detected! Encrypting twice is disabled for now..."
msgstr ""
"Zjištěn pokus o dvojité šifrování! Dvojité šifrování je prozatím "
"deaktivováno..."

#: kategpgplugin.cpp:305
#, kde-format
msgid "Error Encrypting Text! No Matching Fingerprint found...\n"
msgstr "Chyba při šifrování textu! Nebyl nalezen žádný odpovídající otisk...\n"

#: kategpgplugin.cpp:309
#, kde-format
msgid "Error Encrypting Text!"
msgstr "Chyba při šifrování textu!"

#: kategpgplugin.cpp:369
#, kde-format
msgid "Key Fingerprint"
msgstr "Otisk klíče"

#: kategpgplugin.cpp:369
#, kde-format
msgid "Creation Date"
msgstr "Datum vytvoření"

#: kategpgplugin.cpp:369
#, kde-format
msgid "Expiry Date"
msgstr "Datum vypršení platnosti"

#: kategpgplugin.cpp:369
#, kde-format
msgid "Key Length"
msgstr "Délka klíče"

#: kategpgplugin.cpp:369
#, kde-format
msgid "User IDs"
msgstr "ID uživatele"
