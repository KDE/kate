#: kategpgplugin.cpp:75
#, kde-format
msgid "GPG Decrypt current document"
msgstr "GPG deszifratu uneko dokumentua"

#: kategpgplugin.cpp:76
#, kde-format
msgid "GPG Encrypt current document"
msgstr "GPG zifratu uneko dokumentua"

#: kategpgplugin.cpp:80
#, kde-format
msgid "<b>GPG Plugin Settings</b>"
msgstr "<b>GPG Pluginaren ezarpenak</b>"

#: kategpgplugin.cpp:83
#, kde-format
msgid "Key ID"
msgstr "Gako ID"

#: kategpgplugin.cpp:84
#, kde-format
msgid "A search string used to filter keys by available email addresses"
msgstr ""
"Gakoak helbide elektroniko erabilgarrien arabera iragazteko erabiltzen den "
"bilaketa-katea"

#: kategpgplugin.cpp:87
#, kde-format
msgid "Selected GPG Key finerprint for encryption"
msgstr "Zifratzeko hautatutako GPG gakoaren hatz-marka"

#: kategpgplugin.cpp:88
#, kde-format
msgid "<b>To: Email address used for encryption</b>"
msgstr "<b>Nori: zifratzeko erabiltzen den e-posta helbidea</b>"

#: kategpgplugin.cpp:97
#, kde-format
msgid ""
"Select an email address to which to encrypt.\n"
"Only mail addresses associated with your currently selected\n"
"key fingerprint are available."
msgstr ""
"Hautatu zein e-posta helbidetara zifratu.\n"
"Une honetan hautatuta duzun hatz-markarekin lotutako\n"
"posta-helbideak bakarrik daude erabilgarri."

#: kategpgplugin.cpp:101
#, kde-format
msgid ""
"This is your currently selected GPG key fingerprint that will be used for "
"encryption."
msgstr ""
"Hau da unean hautatuta duzun GPG gakoaren hatz-marka, zifratzeko erabiliko "
"dena."

#: kategpgplugin.cpp:104
#, kde-format
msgid "Enable symmetric encryption"
msgstr "Gaitu zifratze simetrikoa"

#: kategpgplugin.cpp:107
#, kde-format
msgid "Show only keys for which a private key is available"
msgstr "Gako pribatua duten gakoak bakarrik erakutsi"

#: kategpgplugin.cpp:110
#, kde-format
msgid "Hide Expired Keys"
msgstr "Ezkutatu iraungitako gakoak"

#: kategpgplugin.cpp:223
#, kde-format
msgid "  Decrypted  "
msgstr ""

#: kategpgplugin.cpp:229
#, fuzzy, kde-format
