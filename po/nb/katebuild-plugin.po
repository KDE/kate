#: plugin_katebuild.cpp:410
#, kde-format
msgid ""
"<b>File not found:</b> %1<br><b>Search paths:</b><br>%2<br>Try adding a "
"search path to the \"Working Directory\""
msgstr ""
"<b>Fant ikke fila:</b> %1<br><b>Søkemapper:</b><br>%2<br>Prøv å legge ei "
"søkemappe til ««arbeidsmappa»"

#: plugin_katebuild.cpp:507
#, kde-format
msgid "Build Information"
msgstr "Byggeinformasjon"

#: plugin_katebuild.cpp:766
#, kde-format
msgid "There is no file or directory specified for building."
msgstr "Det er ikke oppgitt en fil eller mappe for bygging."

#: plugin_katebuild.cpp:770
#, kde-format
msgid ""
"The file \"%1\" is not a local file. Non-local files cannot be compiled."
msgstr "Fila «%1» er ikke en lokal fil. Ikke-lokale filer kan ikke kompileres."

#: plugin_katebuild.cpp:841
#, kde-format
msgid "Create directory"
msgstr "Opprett mappe"

#: plugin_katebuild.cpp:844
#, kde-format
msgid ""
"The configured working directory <b>%1</b> for the targetset <b>%2</b> does "
"not exist.<br><br>Create the directory?"
msgstr ""
"Arbeidsmappa <b>%1</b> som er satt opp for målsettet <b>%2</b> finnes ikke."
"<br> <br> Vil du opprette mappa?"

#: plugin_katebuild.cpp:852
#, kde-format
msgid "Failed to create the directory <b>%1</b>"
msgstr "Klarte ikke å opprette mappa <b>%1</b>"

#: plugin_katebuild.cpp:872
#, kde-format
msgid "Failed to run \"%1\". exitStatus = %2"
msgstr "Klarte ikke kjøre «%1». Avslutningsstatus = %2"

#: plugin_katebuild.cpp:888
#, kde-format
msgid "Building <b>%1: %2</b> cancelled"
msgstr "Bygging av <b>%1: %2</b> er avbrutt"

#: plugin_katebuild.cpp:994
#, kde-format
msgid "Did not find a compile_commands.json for file \"%1\". "
msgstr "Fant ingen «compile_commands.json» for fila «%1». "

#: plugin_katebuild.cpp:1007
#, kde-format
msgid "Did not find a compile command for file \"%1\" in \"%2\". "
msgstr "Fant ingen kompileringskommando for fila «%1» i «%2». "

#: plugin_katebuild.cpp:1026
#, kde-format
msgid ""
"Cannot make \"%f\" substitution. No open file or the current file is "
"untitled!"
msgstr ""
"Kan ikke erstatte «%f». Ingen åpne filer eller så er den gjeldende fila uten "
"navn!"

#: plugin_katebuild.cpp:1030
#, kde-format
msgid ""
"Cannot make \"%d\" substitution. No open file or the current file is "
"untitled!"
msgstr ""
"Kan ikke erstatte «%d». Ingen åpne filer eller så er den gjeldende fila uten "
"navn!"

#: plugin_katebuild.cpp:1034
#, kde-format
msgid ""
"Cannot make \"%n\" substitution. No open file or the current file is "
"untitled!"
msgstr ""
"Kan ikke erstatte «%n». Ingen åpne filer eller så er den gjeldende fila uten "
"navn!"

#: plugin_katebuild.cpp:1045
#, kde-format
msgid "Cannot make project substitution (%B). No open project!"
msgstr "Kan ikke erstatte prosjektet (%B). Ingen åpne prosjekter!"

#: plugin_katebuild.cpp:1058
#, kde-format
msgid "Already building..."
msgstr "Bygger allerede …"

#: plugin_katebuild.cpp:1096
#, kde-format
msgid ""
"Cannot execute: %1: %2 No working directory set.\n"
"There is no local file or directory specified for building."
msgstr ""
"Kan ikke kjøre: %1: %2 Ingen arbeidsmappe er spesifisert.\n"
"Det er ikke oppgitt en lokal fil eller mappe for bygging."

#: plugin_katebuild.cpp:1217
#, kde-format
msgid "Building target <b>%1: %2</b> ..."
msgstr "Bygger målet <b>%1: %2</b> …"

#: plugin_katebuild.cpp:1254
#, kde-format
msgid ""
"Cannot load targets, the file %1 does not contain a proper CMAKE_COMMAND "
"entry !"
msgstr ""
"Klarte ikke laste målene. Fila %1 inneholder ingen skikkelig «CMAKE_COMMAND»-"
"oppføring!"

#: plugin_katebuild.cpp:1267
#, kde-format
msgid "Could not write CMake File API query files for build directory %1 !"
msgstr "Klarte ikke lagre CMake-fil-API-spørrefiler for byggemappa %1 !"

#: plugin_katebuild.cpp:1273
#, kde-format
msgid "Could not run CMake (%2) for build directory %1 !"
msgstr "Klarte ikke kjøre CMake (%2) for byggemappa %1 !"

#: plugin_katebuild.cpp:1282
#, kde-format
msgid ""
"Generating CMake File API reply files for build directory %1 failed (using "
"%2) !"
msgstr ""
"Feil ved generering av CMake-fil-API-svarfiler for byggemappa %1 (bruker "
"%2) !"

#: plugin_katebuild.cpp:1407
#, kde-format
msgid "Build plugin wants to execute program"
msgstr "Byggetillegg ønsker å kjøre et program"

#: plugin_katebuild.cpp:1410
#, kde-format
msgid ""
"The Kate build plugin needs to execute an external command to read the "
"targets from the build tree.<br><br>The full command line is:<br><br><b>%1</"
"b><br><br>Proceed and allow to run this command ?<br><br>The choice can be "
"altered via the config page of the plugin."
msgstr ""
"Kate-byggetillegget ønsker å kjøre en ekstern kommando for å lese målene fra "
"byggetreet.<br><br>Fullstendig kommandolinje:<br><br><b>%1</b><br><br>Vil du "
"fortsette og la det kjøre kommandoen?<br><br>Valget kan endres via "
"oppsettsiden til tillegget."

