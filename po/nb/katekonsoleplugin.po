#: kateconsole.cpp:119 kateconsole.cpp:151 kateconsole.cpp:790
#, kde-format
msgid "Terminal"
msgstr "Terminal"

#: kateconsole.cpp:160
#, kde-format
msgctxt "@action"
msgid "&Pipe to Terminal"
msgstr "&Send i rør til terminalen"

#: kateconsole.cpp:164
#, kde-format
msgctxt "@action"
msgid "S&ynchronize Terminal with Current Document"
msgstr "S&ynkroniser terminalen med gjeldende dokument"

#: kateconsole.cpp:168
#, kde-format
msgctxt "@action"
msgid "Run Current Document"
msgstr "Kjør gjeldende dokument"

#: kateconsole.cpp:173 kateconsole.cpp:575
#, kde-format
msgctxt "@action"
msgid "S&how Terminal Panel"
msgstr "Vis &terminalpanel"

#: kateconsole.cpp:179
#, kde-format
msgctxt "@action"
msgid "&Focus Terminal Panel"
msgstr "&Fokuser terminalpanelet"

#: kateconsole.cpp:185
#, kde-format
msgctxt "@action"
msgid "&Split Terminal Vertically"
msgstr "&Splitt terminalvinduet loddrett"

#: kateconsole.cpp:190
#, kde-format
msgctxt "@action"
msgid "&Split Terminal Horizontally"
msgstr "&Splitt terminalvinduet vannrett"

#: kateconsole.cpp:195
#, kde-format
msgctxt "@action"
msgid "&New Terminal Tab"
msgstr "&Ny terminalfane"

#: kateconsole.cpp:359
#, kde-format
msgid ""
"Konsole not installed. Please install konsole to be able to use the terminal."
msgstr ""
"Konsole er ikke installert. Installer Konsole dersom du vil bruke terminalen."

#: kateconsole.cpp:435
#, kde-format
msgid ""
"Do you really want to pipe the text to the console? This will execute any "
"contained commands with your user rights."
msgstr ""
"Er det sikkert at du vil sende teksten rett til konsollet? Dette vil føre "
"til at eventuelle kommandoer som ligger i teksten blir kjørt med dine "
"brukerrettigheter."

#: kateconsole.cpp:436
#, kde-format
msgid "Pipe to Terminal?"
msgstr "Send i rør til terminalen?"

#: kateconsole.cpp:437
#, kde-format
msgid "Pipe to Terminal"
msgstr "Send i rør til terminalen"

#: kateconsole.cpp:505
#, kde-format
msgid "Not a local file: '%1'"
msgstr "Ikke en lokal fil: «%1»"

#: kateconsole.cpp:538
#, kde-format
msgid ""
"Do you really want to Run the document ?\n"
"This will execute the following command,\n"
"with your user rights, in the terminal:\n"
"'%1'"
msgstr ""
"Er du sikker på at du vil kjøre dokumentet?\n"
"Dette vil kjøre følgende kommando, med\n"
"dine brukerrettigheter i terminalvinduet:\n"
"«%1»"

#: kateconsole.cpp:545
#, kde-format
msgid "Run in Terminal?"
msgstr "Kjøre i terminal?"

#: kateconsole.cpp:546
#, kde-format
msgid "Run"
msgstr "Kjør"

#: kateconsole.cpp:577
#, kde-format
msgctxt "@action"
msgid "&Hide Terminal Panel"
msgstr "&Gjem terminalpanelet"

#: kateconsole.cpp:585
#, kde-format
msgid "Defocus Terminal Panel"
msgstr "Ta fokus vekk fra terminalpanelet"

#: kateconsole.cpp:586 kateconsole.cpp:587
#, kde-format
msgid "Focus Terminal Panel"
msgstr "Fokuser på terminalpanelet"

#: kateconsole.cpp:698
#, kde-format
msgid "Terminal Synchronization Mode"
msgstr "Modus for terminalsynkronisering"

#: kateconsole.cpp:701
#, kde-format
msgid "&Don't synchronize terminal tab with current document"
msgstr "&Ikke synkroniser terminalfanen med gjeldende dokument"

#: kateconsole.cpp:704
#, kde-format
msgid ""
"&Automatically synchronize the current terminal tab with the current "
"document when possible"
msgstr ""
"Synkroniser &automatisk den gjeldende terminalfanen med gjeldende dokument "
"når mulig"

#: kateconsole.cpp:707
#, kde-format
msgid ""
"&Automatically create a terminal tab for the directory of the current "
"document and switch to it"
msgstr ""
"Opprett en terminalfane &automatisk for mappen til det gjeldende dokumentet "
"og bytt til den"

#: kateconsole.cpp:714 kateconsole.cpp:735
#, kde-format
msgid "Run in terminal"
msgstr "Kjør i terminal"

#: kateconsole.cpp:716
#, kde-format
msgid "&Remove extension"
msgstr "Fje&rn etternavn"

#: kateconsole.cpp:721
#, kde-format
msgid "Prefix:"
msgstr "Prefiks:"

#: kateconsole.cpp:729
#, kde-format
msgid "&Show warning next time"
msgstr "Vi&s advarsel neste gang"

#: kateconsole.cpp:731
#, kde-format
msgid ""
"The next time '%1' is executed, make sure a warning window will pop up, "
"displaying the command to be sent to terminal, for review."
msgstr ""
"Sikre at en advarsel spretter opp, som viser kommandoen som er i ferd med å "
"sendes til terminalen slik at den kan kontrolleres før «%1» kjøres."

#: kateconsole.cpp:742
#, kde-format
msgid "Set &EDITOR environment variable to 'kate -b'"
msgstr "Sett miljøvariabelen &EDITOR til «kate -b»"

#: kateconsole.cpp:745
#, kde-format
msgid ""
"Important: The document has to be closed to make the console application "
"continue"
msgstr ""
"Viktig: Dokumentet må være lukket for at konsollprogrammet skal fortsette"

#: kateconsole.cpp:748
#, kde-format
msgid "Hide Konsole on pressing 'Esc'"
msgstr "Gjem Konsole ved å trykke på «Escape»"

#: kateconsole.cpp:751
#, kde-format
msgid ""
"This may cause issues with terminal apps that use Esc key, for e.g., vim. "
"Add these apps in the input below (Comma separated list)"
msgstr ""
"Dette kan skape problemer med terminalprogrammer som bruker «Escape»-tasten, "
"f.eks. Vim. Legg til disse programmene nedenfor (skill programnavnene med "
"komma)"

#: kateconsole.cpp:795
#, kde-format
msgid "Terminal Settings"
msgstr "Terminalinnstillinger"

#. i18n: ectx: Menu (tools)
#: ui.rc:6
#, kde-format
msgid "&Tools"
msgstr "Verk&tøy"
