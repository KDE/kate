#: gpgmeppwrapper.cpp:83
#, kde-format
msgid "Error! No keys found..."
msgstr "Erro! Nenhuma chave encontrada…"

#: gpgmeppwrapper.cpp:133 gpgmeppwrapper.cpp:135
#, kde-format
msgid "Error finding key: "
msgstr "Erro ao encontrar chave:"

#: gpgmeppwrapper.cpp:223 gpgmeppwrapper.cpp:225
#, kde-format
msgid "Error in symmetric encryption: "
msgstr "Erro na criptografia simétrica:"

#: gpgmeppwrapper.cpp:241 gpgmeppwrapper.cpp:243
#, kde-format
msgid "Encryption Failed: "
msgstr "A criptografia falhou:"

#: kategpgplugin.cpp:70
#, kde-format
msgid "GPG Plugin"
msgstr "Plugin GPG"

#: kategpgplugin.cpp:75
#, kde-format
msgid "GPG Decrypt current document"
msgstr "Descriptografar documento atual com GPG"

#: kategpgplugin.cpp:76
#, kde-format
msgid "GPG Encrypt current document"
msgstr "Criptografar documento atual com GPG"

#: kategpgplugin.cpp:80
#, kde-format
msgid "<b>GPG Plugin Settings</b>"
msgstr "<b>Configurações do plugin GPG</b>"

#: kategpgplugin.cpp:83
#, kde-format
msgid "Key ID"
msgstr "ID da chave"

#: kategpgplugin.cpp:84
#, kde-format
msgid "A search string used to filter keys by available email addresses"
msgstr ""
"Um texto de busca usado para filtrar chaves pelos endereços de e-mail "
"disponíveis"

#: kategpgplugin.cpp:87
#, kde-format
msgid "Selected GPG Key finerprint for encryption"
msgstr "Impressão digital da chave GPG selecionada para criptografia"

#: kategpgplugin.cpp:88
#, kde-format
msgid "<b>To: Email address used for encryption</b>"
msgstr "<b>Para: Endereço de e-mail usado para criptografia</b>"

#: kategpgplugin.cpp:97
#, kde-format
msgid ""
"Select an email address to which to encrypt.\n"
"Only mail addresses associated with your currently selected\n"
"key fingerprint are available."
msgstr ""
"Selecione um endereço de e-mail que deseja criptografar.\n"
"Apenas endereços de e-mail associados com sua impressão digital\n"
"selecionada atualmente estão disponíveis."

#: kategpgplugin.cpp:101
#, kde-format
msgid ""
"This is your currently selected GPG key fingerprint that will be used for "
"encryption."
msgstr ""
"Esta é sua impressão digital GPG atualimente selecionada que será usada para "
"criptografia."

#: kategpgplugin.cpp:104
#, kde-format
msgid "Enable symmetric encryption"
msgstr "Habilitar criptografia simétrica"

#: kategpgplugin.cpp:107
#, kde-format
msgid "Show only keys for which a private key is available"
msgstr "Exibir somente chaves para as quais uma chave privada está disponível"

#: kategpgplugin.cpp:110
#, kde-format
msgid "Hide Expired Keys"
msgstr "Ocultar chaves expiradas"

#: kategpgplugin.cpp:223
#, kde-format
msgid "  Decrypted  "
msgstr "  Descriptografado  "

#: kategpgplugin.cpp:229
#, kde-format
msgid "  Encrypted  "
msgstr "  Criptografado  "

#: kategpgplugin.cpp:320 kategpgplugin.cpp:451
#, kde-format
msgid "Error Decrypting Text! No fingerprint selected..."
msgstr "Erro ao descriptografar texto! Nenhuma impressão digital selecionada…"

#: kategpgplugin.cpp:326 kategpgplugin.cpp:456
#, kde-format
msgid ""
"Error Decrypting Text!\n"
"No matching fingerprint found!\n"
"Or this is not a GPG encrypted text..."
msgstr ""
"Erro ao descriptografar texto!\n"
"Nenhuma impressão digital correspondente encontrada!\n"
"Ou não é um texto criptografado pelo GPG…"

#: kategpgplugin.cpp:334 kategpgplugin.cpp:464
#, kde-format
msgid "Error Decrypting Text!\n"
msgstr "Erro ao descriptografar texto!\n"

#: kategpgplugin.cpp:416 kategpgplugin.cpp:503
#, kde-format
msgid ""
"Error Encrypting Text!\n"
"No fingerprint selected..."
msgstr ""
"Erro ao criptografar texto!\n"
"Nenhuma impressão digital selecionada…"

#: kategpgplugin.cpp:423 kategpgplugin.cpp:547
#, kde-format
msgid "Error Encrypting Text! No Matching Fingerprint found...\n"
msgstr ""
"Erro ao criptografar texto! Nenhuma impressão digital correspondente "
"encontrada…\n"

#: kategpgplugin.cpp:427 kategpgplugin.cpp:551
#, kde-format
msgid "Error Encrypting Text!"
msgstr "Erro ao criptografar texto!"

#: kategpgplugin.cpp:443 kategpgplugin.cpp:490
#, kde-format
msgid "Error! No views available..."
msgstr "Erro! Nenhuma vista disponível…"

#: kategpgplugin.cpp:447
#, kde-format
msgid "Error Decrypting Text! Document is empty..."
msgstr "Erro ao descriptografar texto! O documento está vazio…"

#: kategpgplugin.cpp:495
#, kde-format
msgid "Error Encrypting Text! No document available..."
msgstr "Erro ao criptografar texto! Nenhum documento disponível…"

#: kategpgplugin.cpp:499
#, kde-format
msgid "Error Encrypting Text! Document is empty..."
msgstr "Erro ao criptografar texto! O documento está vazio…"

#: kategpgplugin.cpp:507
#, kde-format
msgid ""
"Attempted double encryption detected! Encrypting twice is disabled for now..."
msgstr ""
"Tentativa de criptografia dupla detectada! A criptografia dupla está "
"desabilitada por enquanto…"

#: kategpgplugin.cpp:528
#, kde-format
msgid "Save Encrypted File As"
msgstr "Salvar arquivo criptografado como"

#: kategpgplugin.cpp:530
#, kde-format
msgid "GPG Files (*.gpg *.asc)"
msgstr "Arquivos GPG (*.gpg *.asc)"

#: kategpgplugin.cpp:619
#, kde-format
msgid "Key Fingerprint"
msgstr "Impressão digital da chave:"

#: kategpgplugin.cpp:619
#, kde-format
msgid "Creation Date"
msgstr "Data de criação"

#: kategpgplugin.cpp:619
#, kde-format
msgid "Expiry Date"
msgstr "Data de expiração"

#: kategpgplugin.cpp:619
#, kde-format
msgid "Key Length"
msgstr "Comprimento da chave"

#: kategpgplugin.cpp:619
#, kde-format
msgid "User IDs"
msgstr "IDs de usuário"

#~ msgid "Save as ASCII encoded (.asc/.gpg)"
#~ msgstr "Salvar com codificação em ASCII (.asc/.gpg)"

