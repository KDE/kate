#: colorpickerconfigpage.cpp:34
#, kde-format
msgid "Show preview for known color names"
msgstr "Arată previzualizare pentru denumiri de culori cunoscute"

#: colorpickerconfigpage.cpp:36
#, kde-format
msgid ""
"Also show the color picker for known color names (e.g. skyblue).\n"
"See https://www.w3.org/TR/SVG11/types.html#ColorKeywords for the list of "
"colors."
msgstr ""
"Arată selectorul de culori și pentru denumiri de culori cunoscute (ca "
"„skyblue”).\n"
"Vedeți https://www.w3.org/TR/SVG11/types.html#ColorKeywords pentru lista "
"culorilor."

#: colorpickerconfigpage.cpp:39
#, kde-format
msgid "Place preview after text color"
msgstr "Amplasează previzualizarea după textul culorii"

#: colorpickerconfigpage.cpp:53
#, kde-format
msgid "Hex color matching"
msgstr "Potrivirea culorilor hexazecimale"

#: colorpickerconfigpage.cpp:56
#, kde-format
msgid "12 digits (#RRRRGGGGBBBB)"
msgstr "12 cifre (#RRRRGGGGBBBB)"

#: colorpickerconfigpage.cpp:57
#, kde-format
msgid "9 digits (#RRRGGGBBB)"
msgstr "9 cifre (#RRRGGGBBB)"

#: colorpickerconfigpage.cpp:58
#, kde-format
msgid "8 digits (#AARRGGBB)"
msgstr "8 cifre (#AARRGGBB)"

#: colorpickerconfigpage.cpp:59
#, kde-format
msgid "6 digits (#RRGGBB)"
msgstr "6 cifre (#RRGGBB)"

#: colorpickerconfigpage.cpp:60
#, kde-format
msgid "3 digits (#RGB)"
msgstr "3 cifre (#RGB)"

#: colorpickerconfigpage.cpp:84
#, kde-format
