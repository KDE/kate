#: tabswitcher.cpp:57
#, kde-format
msgid "Document Switcher"
msgstr "Comutator de documente"

#: tabswitcher.cpp:102
#, kde-format
msgid "Last Used Views"
msgstr "Ultimele vizualizări utilizate"

#: tabswitcher.cpp:105
#, kde-format
msgid "Opens a list to walk through the list of last used views."
msgstr ""
"Deschide o listă pentru a parcurge lista ultimelor vizualizări utilizate."

#: tabswitcher.cpp:106 tabswitcher.cpp:114
#, kde-format
msgid "Walk through the list of last used views"
msgstr "Parcurge lista ultimelor vizualizări utilizate"

#: tabswitcher.cpp:110
#, kde-format
msgid "Last Used Views (Reverse)"
msgstr "Ultimele vizualizări utilizate (invers)"

#: tabswitcher.cpp:113
#, kde-format
msgid "Opens a list to walk through the list of last used views in reverse."
msgstr ""
"Deschide o listă pentru a parcurge invers lista ultimelor vizualizări "
"utilizate."

#: tabswitcher.cpp:118
#, kde-format
msgid "Close View"
msgstr "Închide vizualizarea"

#: tabswitcher.cpp:121 tabswitcher.cpp:122
#, kde-format
msgid "Closes the selected view in the list of last used views."
msgstr "Închide vizualizarea aleasă din lista ultimelor vizualizări utilizate."

