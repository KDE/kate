#~ "Attempted double encryption detected!\n"
#~ "Encrypting more than once is disabled for now..."
#~ msgstr ""
#~ "Zaznan poskus dvojnega šifriranja!\n"
#~ "Šifriranje več kot enkrat je zaenkrat onemogočeno..."

#~ msgid "Warning"
#~ msgstr "Opozorilo"

