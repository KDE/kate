#: gpgmeppwrapper.cpp:83
#, kde-format
msgid "Error! No keys found..."
msgstr "Napaka! Ni najdenih ključev..."

#: gpgmeppwrapper.cpp:133 gpgmeppwrapper.cpp:135
#, kde-format
msgid "Error finding key: "
msgstr "Napaka pri iskanju ključa: "

#: gpgmeppwrapper.cpp:223 gpgmeppwrapper.cpp:225
#, kde-format
msgid "Error in symmetric encryption: "
msgstr "Napaka v simetričnem šifriranju: "

#: gpgmeppwrapper.cpp:241 gpgmeppwrapper.cpp:243
#, kde-format
msgid "Encryption Failed: "
msgstr "Šifriranje ni uspelo: "

#: kategpgplugin.cpp:70
#, kde-format
msgid "GPG Plugin"
msgstr "Vtičnik GPG"

#: kategpgplugin.cpp:75
#, kde-format
msgid "GPG Decrypt current document"
msgstr "Dešifriraj trenutni dokument GPG"

#: kategpgplugin.cpp:76
#, kde-format
msgid "GPG Encrypt current document"
msgstr "Šifriraj trenutni dokument GPG"

#: kategpgplugin.cpp:80
#, kde-format
msgid "<b>GPG Plugin Settings</b>"
msgstr "<b>Nastavitve vtičnika GPG</b>"

#: kategpgplugin.cpp:83
#, kde-format
msgid "Key ID"
msgstr "ID ključa"

#: kategpgplugin.cpp:84
#, kde-format
msgid "A search string used to filter keys by available email addresses"
msgstr ""
"Iskalni niz, ki se uporablja za filtriranje ključev po razpoložljivih e-"
"poštnih naslovih"

#: kategpgplugin.cpp:87
#, kde-format
msgid "Selected GPG Key finerprint for encryption"
msgstr "Izbrani natančnejši odtis ključa GPG za šifriranje"

#: kategpgplugin.cpp:88
#, kde-format
msgid "<b>To: Email address used for encryption</b>"
msgstr "<b>Za: e-poštni naslov, ki se uporablja za šifriranje</b>"

#: kategpgplugin.cpp:97
#, kde-format
msgid ""
"Select an email address to which to encrypt.\n"
"Only mail addresses associated with your currently selected\n"
"key fingerprint are available."
msgstr ""
"Izberite e-poštni naslov, na katerega želite šifrirati. Na voljo so samo e-"
"poštni naslovi, povezani z vašim trenutno izbranim prstnim odtisom ključa."

#: kategpgplugin.cpp:101
#, kde-format
msgid ""
"This is your currently selected GPG key fingerprint that will be used for "
"encryption."
msgstr ""
"To je vaš trenutno izbrani prstni odtis ključa GPG, ki bo uporabljen za "
"šifriranje."

#: kategpgplugin.cpp:104
#, kde-format
msgid "Enable symmetric encryption"
msgstr "Omogoči simetrično šifriranje"

#: kategpgplugin.cpp:107
#, kde-format
msgid "Show only keys for which a private key is available"
msgstr "Prikaži samo ključe, za katere je na voljo zasebni ključ"

#: kategpgplugin.cpp:110
#, kde-format
msgid "Hide Expired Keys"
msgstr "Skrij potekle ključe"

#: kategpgplugin.cpp:223
#, kde-format
msgid "  Decrypted  "
msgstr "  Dešifrirano  "

#: kategpgplugin.cpp:229
#, kde-format
msgid "  Encrypted  "
msgstr "  Šifrirano  "

#: kategpgplugin.cpp:320 kategpgplugin.cpp:451
#, kde-format
msgid "Error Decrypting Text! No fingerprint selected..."
msgstr "Napaka pri dešifriranju besedila! Ni izbranega prstnega odtisa ..."

#: kategpgplugin.cpp:326 kategpgplugin.cpp:456
#, kde-format
msgid ""
"Error Decrypting Text!\n"
"No matching fingerprint found!\n"
"Or this is not a GPG encrypted text..."
msgstr ""
"Napaka pri dešifriranju besedila!\n"
"Ni najdenega ujemajočega se prstnega odtisa!\n"
"Ali pa to ni GPG šifrirano besedilo..."

#: kategpgplugin.cpp:334 kategpgplugin.cpp:464
#, kde-format
msgid "Error Decrypting Text!\n"
msgstr "Napaka pri dešifriranju besedila!\n"

#: kategpgplugin.cpp:416 kategpgplugin.cpp:503
#, kde-format
msgid ""
"Error Encrypting Text!\n"
"No fingerprint selected..."
msgstr ""
"Napaka pri šifriranju besedila!\n"
"Ni izbranega prstnega odtisa..."

#: kategpgplugin.cpp:423 kategpgplugin.cpp:547
#, kde-format
msgid "Error Encrypting Text! No Matching Fingerprint found...\n"
msgstr ""
"Napaka pri šifriranju besedila! Ni najdenega ujemajočega se prstnega "
"odtisa...\n"

#: kategpgplugin.cpp:427 kategpgplugin.cpp:551
#, kde-format
msgid "Error Encrypting Text!"
msgstr "Napaka pri šifriranju besedila!"

#: kategpgplugin.cpp:443 kategpgplugin.cpp:490
#, kde-format
msgid "Error! No views available..."
msgstr "Napaka! Ni na voljo pogledov..."

#: kategpgplugin.cpp:447
#, kde-format
msgid "Error Decrypting Text! Document is empty..."
msgstr "Napaka pri dešifriranju besedila! Dokument je prazen..."

#: kategpgplugin.cpp:495
#, kde-format
msgid "Error Encrypting Text! No document available..."
msgstr "Napaka pri šifriranju besedila! Ni na voljo nobenega dokumenta..."

#: kategpgplugin.cpp:499
#, kde-format
msgid "Error Encrypting Text! Document is empty..."
msgstr "Napaka pri šifriranju besedila! Dokument je prazen..."

#: kategpgplugin.cpp:507
#, kde-format
msgid ""
"Attempted double encryption detected! Encrypting twice is disabled for now..."
msgstr ""
"Zaznan poskus dvojnega šifriranja! Dvojno šifriranje je zaenkrat "
"onemogočeno ..."

#: kategpgplugin.cpp:528
#, kde-format
msgid "Save Encrypted File As"
msgstr "Shrani šifrirano datoteko kot"

#: kategpgplugin.cpp:530
#, kde-format
msgid "GPG Files (*.gpg *.asc)"
msgstr "Datoteke GPG (*.gpg *.asc)"

#: kategpgplugin.cpp:619
#, kde-format
msgid "Key Fingerprint"
msgstr "Prstni odtis ključa"

#: kategpgplugin.cpp:619
#, kde-format
msgid "Creation Date"
msgstr "Datum nastanka"

#: kategpgplugin.cpp:619
#, kde-format
msgid "Expiry Date"
msgstr "Datum poteka veljavnosti"

#: kategpgplugin.cpp:619
#, kde-format
msgid "Key Length"
msgstr "Dolžina ključa"

#: kategpgplugin.cpp:619
#, kde-format
msgid "User IDs"
msgstr "ID-ji uporabnikov"

#~ msgid "Save as ASCII encoded (.asc/.gpg)"
#~ msgstr "Shrani kot kodirano ASCII (.asc/.gpg)"

