#: gpgmeppwrapper.cpp:83
#, kde-format
msgid "Error! No keys found..."
msgstr "Hata! Bulunan anahtar yok."

#: gpgmeppwrapper.cpp:133 gpgmeppwrapper.cpp:135
#, kde-format
msgid "Error finding key: "
msgstr "Anahtar bulunurken hata: "

#: gpgmeppwrapper.cpp:223 gpgmeppwrapper.cpp:225
#, kde-format
msgid "Error in symmetric encryption: "
msgstr "Simetrik şifrelemede hata: "

#: gpgmeppwrapper.cpp:241 gpgmeppwrapper.cpp:243
#, kde-format
msgid "Encryption Failed: "
msgstr "Şifreleme başarısız: "

#: kategpgplugin.cpp:70
#, kde-format
msgid "GPG Plugin"
msgstr "GPG Eklentisi"

#: kategpgplugin.cpp:75
#, kde-format
msgid "GPG Decrypt current document"
msgstr "Geçerli Belgenin Şifresini GPG ile Çöz"

#: kategpgplugin.cpp:76
#, kde-format
msgid "GPG Encrypt current document"
msgstr "Geçerli Belgeyi GPG ile Şifrele"

#: kategpgplugin.cpp:80
#, kde-format
msgid "<b>GPG Plugin Settings</b>"
msgstr "<b>GPG Eklentisi Ayarları</b>"

#: kategpgplugin.cpp:83
#, kde-format
msgid "Key ID"
msgstr "Anahtar kimliği"

#: kategpgplugin.cpp:84
#, kde-format
msgid "A search string used to filter keys by available email addresses"
msgstr ""
"Kullanılabilir e-posta adresleri arasından anahtarları süzmek için "
"kullanılan bir arama dizisi"

#: kategpgplugin.cpp:87
#, kde-format
msgid "Selected GPG Key finerprint for encryption"
msgstr "Şifreleme için seçili GPG anahtar parmak izi"

#: kategpgplugin.cpp:88
#, kde-format
msgid "<b>To: Email address used for encryption</b>"
msgstr "<b>Kime:</b> Şifreleme için kullanılan e-posta adresi"

#: kategpgplugin.cpp:97
#, kde-format
msgid ""
"Select an email address to which to encrypt.\n"
"Only mail addresses associated with your currently selected\n"
"key fingerprint are available."
msgstr ""
"Kendisine şifrelenecek bir e-posta adresi seçin.\n"
"Yalnızca şu anda seçili anahtar parmak izinizle ilişkilendirilmiş\n"
"e-posta adresleri kullanılabilirdir."

#: kategpgplugin.cpp:101
#, kde-format
msgid ""
"This is your currently selected GPG key fingerprint that will be used for "
"encryption."
msgstr ""
"Bu, şu anda seçili olan ve şifreleme için kullanılacak GPG anahtarınızdır."

#: kategpgplugin.cpp:104
#, kde-format
msgid "Enable symmetric encryption"
msgstr "Simetrek şifrelemeyi etkinleştir"

#: kategpgplugin.cpp:107
#, kde-format
msgid "Show only keys for which a private key is available"
msgstr "Yalnızca kullanılabilir bir özel anahtarı olan anahtarları göster"

#: kategpgplugin.cpp:110
#, kde-format
msgid "Hide Expired Keys"
msgstr "Süresi dolmuş anahtarları gizle"

#: kategpgplugin.cpp:223
#, kde-format
msgid "  Decrypted  "
msgstr "  Şifresi Çözülü  "

#: kategpgplugin.cpp:229
#, kde-format
msgid "  Encrypted  "
msgstr "  Şifrelenmiş  "

#: kategpgplugin.cpp:320 kategpgplugin.cpp:451
#, kde-format
msgid "Error Decrypting Text! No fingerprint selected..."
msgstr "Metin şifresi çözülürken hata! Seçili parmak izi yok."

#: kategpgplugin.cpp:326 kategpgplugin.cpp:456
#, kde-format
msgid ""
"Error Decrypting Text!\n"
"No matching fingerprint found!\n"
"Or this is not a GPG encrypted text..."
msgstr ""
"Metin şifresi çözülürken hata!\n"
"Eşleşen parmak izi bulunamadı veya\n"
"bu GPG ile şifrelenmiş bir metin değil."

#: kategpgplugin.cpp:334 kategpgplugin.cpp:464
#, kde-format
msgid "Error Decrypting Text!\n"
msgstr "Metin şifresi çözülürken hata!\n"

#: kategpgplugin.cpp:416 kategpgplugin.cpp:503
#, kde-format
msgid ""
"Error Encrypting Text!\n"
"No fingerprint selected..."
msgstr ""
"Metin şifresi çözülürken hata!\n"
"Seçili parmak izi yok."

#: kategpgplugin.cpp:423 kategpgplugin.cpp:547
#, kde-format
msgid "Error Encrypting Text! No Matching Fingerprint found...\n"
msgstr "Metin şifresi çözülürken hata! Eşleşen parmak izi bulunamadı.\n"

#: kategpgplugin.cpp:427 kategpgplugin.cpp:551
#, kde-format
msgid "Error Encrypting Text!"
msgstr "Metin şifresi çözülürken hata!"

#: kategpgplugin.cpp:443 kategpgplugin.cpp:490
#, kde-format
msgid "Error! No views available..."
msgstr "Hata! Kullanılabilir görünüm yok."

#: kategpgplugin.cpp:447
#, kde-format
msgid "Error Decrypting Text! Document is empty..."
msgstr "Metin şifresi çözülürken hata! Belge boş."

#: kategpgplugin.cpp:495
#, kde-format
msgid "Error Encrypting Text! No document available..."
msgstr "Metin şifresi çözülürken hata! Kullanılabilir belge yok."

#: kategpgplugin.cpp:499
#, kde-format
msgid "Error Encrypting Text! Document is empty..."
msgstr "Metin şifresi çözülürken hata! Belge boş."

#: kategpgplugin.cpp:507
#, kde-format
msgid ""
"Attempted double encryption detected! Encrypting twice is disabled for now..."
msgstr ""
"Çifte şifreleme denemesi algılandı! Bu özellik, şu an için devre dışıdır."

#: kategpgplugin.cpp:528
#, kde-format
msgid "Save Encrypted File As"
msgstr "Şifreli Dosyayı Farklı Kaydet"

#: kategpgplugin.cpp:530
#, kde-format
msgid "GPG Files (*.gpg *.asc)"
msgstr "GPG dosyaları (*.gpg *.asc)"

#: kategpgplugin.cpp:619
#, kde-format
msgid "Key Fingerprint"
msgstr "Anahtar parmak izi"

#: kategpgplugin.cpp:619
#, kde-format
msgid "Creation Date"
msgstr "Oluşturulma tarihi"

#: kategpgplugin.cpp:619
#, kde-format
msgid "Expiry Date"
msgstr "Son kullanım tarihi"

#: kategpgplugin.cpp:619
#, kde-format
msgid "Key Length"
msgstr "Anahtar uzunluğu"

#: kategpgplugin.cpp:619
#, kde-format
msgid "User IDs"
msgstr "Kullanıcı kimlikleri"

#~ msgid "Save as ASCII encoded (.asc/.gpg)"
#~ msgstr "ASCII kodlu olarak kaydet (.asc/.gpg)"

