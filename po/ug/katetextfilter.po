#: plugin_katetextfilter.cpp:89
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<title>Result of:</title><nl /><pre><code>$ %1\n"
"<nl />%2</code></pre>"
msgstr ""
"<title>نەتىجە:</title><nl /><pre><code>$ %1\n"
"<nl />%2</code></pre>"

#: plugin_katetextfilter.cpp:142
#, kde-format
msgid "Failed to start process"
msgstr "جەرياننى قوزغىتالمىدى"

#: plugin_katetextfilter.cpp:156
#, kde-format
msgid ""
"You are not allowed to execute arbitrary external applications. If you want "
"to be able to do this, contact your system administrator."
msgstr ""
"بۇ سىرتقى پىروگراممىنى ئىجرا قىلىشىڭىزغا يول قويۇلمىغان. ئەگەر بۇ چەكلىمىنى "
"بىكار قىلماقچى بولسىڭىز، سىستېما باشقۇرغۇچىڭىز بىلەن ئالاقىلىشىڭ."

#: plugin_katetextfilter.cpp:158
#, kde-format
msgid "Access Restrictions"
msgstr "زىيارەت چەكلىمىسى"

#: plugin_katetextfilter.cpp:176 plugin_katetextfilter.cpp:264
#, kde-format
msgid "Text Filter"
msgstr "تېكىست سۈزگۈچ"

#: plugin_katetextfilter.cpp:242
#, kde-format
msgid "Usage: textfilter COMMAND"
msgstr "ئىشلىتىش ئۇسۇلى: textfilter COMMAND"

#: plugin_katetextfilter.cpp:253
#, kde-format
msgid ""
"<qt><p>Usage: <code>textfilter COMMAND</code></p><p>Replace the selection "
"with the output of the specified shell command.</p></qt>"
msgstr ""
"<qt><p>ئىشلىتىش ئۇسۇلى: <code>textfilter COMMAND</code></p><p>تاللانغان "
"دائىرە بەلگىلەنگەن shell بۇيرۇقىغا ئالماشتۇرۇلىدۇ.</p></qt>"

#: plugin_katetextfilter.cpp:269
#, kde-format
msgid "&Filter Through Command..."
msgstr "بۇيرۇق ئارقىلىق سۈز(&F)…"

#. i18n: ectx: property (windowTitle), widget (QDialog, TextFilterWidget)
#: textfilterwidget.ui:14
#, kde-format
msgid "Dialog"
msgstr "سۆزلەشكۈ"

#. i18n: ectx: property (text), widget (QLabel, lblFilter)
#: textfilterwidget.ui:26
#, kde-format
msgid "Enter command to &pipe selected text through:"
msgstr ""
"تۇرۇبا ئارقىلىق تاللىغان تېكىستنى بىر تەرەپ قىلىدىغان بۇيرۇق كىرگۈزۈلىدۇ:"

#. i18n: ectx: property (text), widget (QCheckBox, newDoc)
#: textfilterwidget.ui:39
#, kde-format
msgid "Open results in a new document"
msgstr "نەتىجىنى يېڭى پۈتۈكتە ئاچ"

#. i18n: ectx: property (toolTip), widget (QCheckBox, copyResult)
#: textfilterwidget.ui:46
#, kde-format
msgid "Copy the result to clipboard leaving a document unchanged."
msgstr ""
"نەتىجىنى چاپلاش تاختىسىغا كۆچۈرۈپ پۈتۈكنى ئۆزگەرتمەي شۇ پېتى قالدۇرىدۇ."

#. i18n: ectx: property (text), widget (QCheckBox, copyResult)
#: textfilterwidget.ui:49
#, kde-format
msgid "Copy the result instead of pasting it"
msgstr "نەتىجىنى چاپلىماستىن كۆچۈر"

#. i18n: ectx: property (toolTip), widget (QCheckBox, mergeOutput)
#: textfilterwidget.ui:57
#, kde-format
msgid ""
"If checked, an output from STDOUT and STDERR will be merged and no errors "
"will be reported.\n"
"Otherwise, STDERR will be displayed as a passive message."
msgstr ""
"ئەگەر تاللانسا، STDOUT ۋە STDERR نىڭ چىقىرىشى بىرلەشتۈرۈلىدۇ ۋە خاتالىق "
"مەلۇم قىلمايدۇ.\n"
"تاللانمىسا، STDERR نى خاتالىق سۈپىتىدە كۆرسىتىدۇ."

#. i18n: ectx: property (text), widget (QCheckBox, mergeOutput)
#: textfilterwidget.ui:60
#, kde-format
msgid "Merge STDOUT and STDERR"
msgstr "STDOUT ۋە STDERR نى بىرلەشتۈر"

#. i18n: ectx: Menu (tools)
#: ui.rc:6
#, kde-format
msgid "&Tools"
msgstr "قورال(&T)"

